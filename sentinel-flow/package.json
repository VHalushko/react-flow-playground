{
  "name": "@sentinel-flow/source",
  "version": "0.0.0",
  "license": "MIT",
  "scripts": {
    "dev": "npx nx run-many --target=dev --projects=@sentinel-flow/web,@sentinel-flow/api --parallel",
    "dev:web": "npx nx dev @sentinel-flow/web",
    "dev:api": "npx nx serve @sentinel-flow/api",
    "build": "npx nx run-many --target=build --all",
    "build:web": "npx nx build @sentinel-flow/web",
    "build:api": "npx nx build @sentinel-flow/api",
    "test": "npx nx run-many --target=test --all",
    "test:watch": "npx nx run-many --target=test --all -- --watch",
    "lint": "npx nx run-many --target=lint --all",
    "typecheck": "npx nx run-many --target=typecheck --all",
    "e2e": "npx nx e2e @sentinel-flow/web-e2e",
    "affected:test": "npx nx affected --target=test",
    "affected:build": "npx nx affected --target=build",
    "affected:lint": "npx nx affected --target=lint"
  },
  "private": true,
  "dependencies": {
